<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpark.estacionamiento.controller.MainDashboardController"
            stylesheets="@css/styles.css"
            prefHeight="600.0" prefWidth="900.0" styleClass="root">

    <top>
        <HBox alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #ecf0f1;">
            <Label text="🅿️ SmartPark - Gestión Inteligente" styleClass="label-header"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.4" style="-fx-background-color: transparent;">

            <VBox spacing="15" styleClass="panel-container" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Control de Acceso" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Separator/>

                <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="Registrar Entrada" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="placaTextField" promptText="Placa (Ej: ABC-123)" />
                    <ComboBox fx:id="tipoVehiculoComboBox" promptText="Tipo de Vehículo" maxWidth="Infinity"/>
                    <ComboBox fx:id="slotComboBox" promptText="Seleccione Espacio" maxWidth="Infinity"/>
                    <Button text="Ingresar Vehículo" onAction="#handleRegistrarEntrada"
                            styleClass="button-success" maxWidth="Infinity"/>
                </VBox>

                <Separator/>

                <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="Registrar Salida" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="placaSalidaTextField" promptText="Buscar por Placa" />
                    <CheckBox fx:id="lavadoCheckBox" text="Servicio de Lavado (+S/20.00)" />
                    <HBox spacing="10">
                        <Button text="Cobrar y Salir" onAction="#handleRegistrarSalida"
                                styleClass="button-danger" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        <Button text="↩" onAction="#handleDeshacer"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white;">
                            <tooltip>
                                <Tooltip text="Deshacer última salida" />
                            </tooltip>
                        </Button>
                    </HBox>
                </VBox>

                <Separator/>

                <Button text="Ver Reporte Financiero" onAction="#handleVerReporte"
                        styleClass="button-action" maxWidth="Infinity"/>

                <Button text="Ver Historial Completo" onAction="#handleVerHistorial"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                        maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="15" styleClass="panel-container">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="Mapa del Estacionamiento" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Verde: Disponible | Rojo: Ocupado" style="-fx-text-fill: #7f8c8d;"/>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <GridPane fx:id="parkingGrid" hgap="10" vgap="10" alignment="CENTER"/>
                </ScrollPane>
            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 5;">
            <Label fx:id="statusLabel" text="Sistema listo." textFill="white"/>
        </HBox>
    </bottom>

</BorderPane>