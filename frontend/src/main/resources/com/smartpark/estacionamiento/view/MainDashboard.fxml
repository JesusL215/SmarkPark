<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainBorderPane" stylesheets="@css/styles.css" styleClass="main-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.estacionamiento.controller.MainDashboardController">

    <left>
        <VBox styleClass="sidebar" prefWidth="240.0" spacing="10.0">
            <padding>
                <Insets top="20.0" bottom="20.0"/>
            </padding>

            <Label text="🅿 SmartPark" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 30 20;"/>

            <Button fx:id="btnDashboard" text="  Dashboard" onAction="#handleVerDashboard" prefWidth="240.0" styleClass="nav-button, nav-button-active"/>
            <Button fx:id="btnReportes" text="  Reportes" onAction="#handleVerReporte" prefWidth="240.0" styleClass="nav-button"/>
            <Button fx:id="btnHistorial" text="  Historial" onAction="#handleVerHistorial" prefWidth="240.0" styleClass="nav-button"/>
            <Button fx:id="btnAdministracion" text="  Administración" onAction="#handleVerAdministracion" prefWidth="240.0" styleClass="nav-button"/>

            <Region VBox.vgrow="ALWAYS" />

            <VBox alignment="CENTER" style="-fx-padding: 20.0;">
                <Button text="Cerrar Sesión" onAction="#handleCerrarSesion" prefWidth="200.0" styleClass="btn-danger"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <HBox fx:id="vistaDashboard" spacing="30.0">
            <padding><Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/></padding>

            <VBox spacing="25.0" prefWidth="350.0">
                <Label text="Control de Acceso" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>

                <VBox spacing="15.0" styleClass="fluent-card">
                    <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
                    <Label text="Registrar Entrada" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="placaTextField" promptText="Placa del Vehículo"/>
                    <ComboBox fx:id="tipoVehiculoComboBox" promptText="Tipo de Vehículo" prefWidth="310.0"/>
                    <ComboBox fx:id="slotComboBox" promptText="Seleccione Espacio" prefWidth="310.0"/>
                    <Button text="Ingresar Vehículo" onAction="#handleRegistrarEntrada" prefWidth="310.0" styleClass="btn-success"/>
                </VBox>

                <VBox spacing="15.0" styleClass="fluent-card">
                    <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
                    <Label text="Registrar Salida" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="placaSalidaTextField" promptText="Buscar por Placa"/>
                    <CheckBox fx:id="lavadoCheckBox" text="Servicio de Lavado (+S/20)" style="-fx-text-fill: #475569;"/>
                    <Button text="Cobrar y Salir" onAction="#handleRegistrarSalida" prefWidth="310.0" styleClass="btn-primary"/>
                </VBox>
            </VBox>

            <VBox spacing="25.0" HBox.hgrow="ALWAYS">
                <Label text="Mapa del Estacionamiento" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label fx:id="statusLabel" text="Conectado al servidor." style="-fx-text-fill: #10B981; -fx-font-weight: bold;"/>

                <VBox styleClass="fluent-card" VBox.vgrow="ALWAYS">
                    <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
                    <GridPane fx:id="parkingGrid" hgap="15.0" vgap="15.0" alignment="CENTER"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>