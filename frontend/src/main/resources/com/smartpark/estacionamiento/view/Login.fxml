<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="login-bg" stylesheets="@css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartpark.estacionamiento.controller.LoginController">

    <VBox alignment="CENTER" maxWidth="400.0" maxHeight="450.0" spacing="25.0" styleClass="glass-card">
        <padding>
            <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
        </padding>

        <Label text="SmartPark" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
        <Label text="Iniciar Sesión" style="-fx-font-size: 16px; -fx-text-fill: #64748B;"/>

        <VBox spacing="15.0">
            <TextField fx:id="txtUsername" promptText="Nombre de usuario" prefHeight="45.0"/>
            <PasswordField fx:id="txtPassword" promptText="Contraseña" prefHeight="45.0"/>
        </VBox>

        <Button text="INGRESAR" onAction="#handleLogin" prefWidth="320.0" prefHeight="45.0" styleClass="btn-primary" defaultButton="true"/>

        <Label fx:id="lblError" textFill="#EF4444" wrapText="true" textAlignment="CENTER"/>
    </VBox>

</StackPane>